# Required only when the QR login user should not be the sole allowed sender.
# WECHAT_BRIDGE_ALLOW_FROM=user1@im.wechat,user2@im.wechat
# WECHAT_BRIDGE_ALLOW_ALL=0

# Initial workspace and safety mode for a peer that has no saved settings yet.
WECHAT_BRIDGE_CWD=/absolute/path/to/a/project
WECHAT_BRIDGE_ACCESS_MODE=workspace
WECHAT_BRIDGE_DEFAULT_AGENT=codex

# Agent execution.
WECHAT_BRIDGE_TIMEOUT_MS=600000
# WECHAT_BRIDGE_CODEX_DEFAULT_MODEL=gpt-5.5
# WECHAT_BRIDGE_CLAUDE_CODE_MODEL=sonnet
# WECHAT_BRIDGE_CLAUDE_CODE_EFFORT=high

# Queue and transport tuning. Defaults are normally appropriate.
WECHAT_BRIDGE_INPUT_DEBOUNCE_MS=650
WECHAT_BRIDGE_MAX_PENDING_MESSAGES=20
WECHAT_BRIDGE_MAX_CONCURRENT_AGENTS=2
WECHAT_BRIDGE_SEND_INTERVAL_MS=2500
WECHAT_BRIDGE_SEND_MAX_RETRIES=2
WECHAT_BRIDGE_SEND_MAX_PENDING=200
WECHAT_BRIDGE_SEND_CRITICAL_RESERVE=512
WECHAT_BRIDGE_PROGRESS_INTERVAL_MS=45000

# Optional state override. New installations default to ~/.weclaudex; an
# existing legacy state directory is reused so QR credentials are not lost.
# WECHAT_BRIDGE_STATE_DIR=/absolute/private/path
