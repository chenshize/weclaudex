{
  "name": "weclaudex",
  "version": "0.7.2",
  "private": false,
  "type": "module",
  "description": "Control your local Claude Code and Codex from WeChat with resumable sessions, durable queues, safe workspaces, media, and explicit artifact delivery.",
  "keywords": [
    "wechat",
    "weclaudex",
    "codex",
    "claude-code",
    "coding-agent",
    "ai-agent",
    "developer-tools",
    "remote-control",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenshize/weclaudex.git"
  },
  "homepage": "https://github.com/chenshize/weclaudex#readme",
  "bugs": {
    "url": "https://github.com/chenshize/weclaudex/issues"
  },
  "bin": {
    "weclaudex": "src/cli.js"
  },
  "files": [
    "src/",
    "CHANGELOG.md",
    "README.en.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "init": "node ./src/cli.js init",
    "login": "node ./src/cli.js login",
    "run": "node ./src/cli.js run",
    "doctor": "node ./src/cli.js doctor",
    "test": "node --test",
    "test:package": "node ./scripts/verify-package.mjs",
    "check": "node --check src/cli.js && node --check src/bridge.js && node --test",
    "prepublishOnly": "npm run check && npm run test:package"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0"
  },
  "engines": {
    "node": ">=22"
  }
}
